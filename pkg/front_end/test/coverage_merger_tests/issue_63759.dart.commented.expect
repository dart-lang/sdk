// ignore_for_file: unnecessary_type_name_in_constructor

void main(List<String> args) {
  print([
    for (String s
        in args
            .map(
              // Coverage-ignore(suite): Not run.
              (s) => "$s!",
            )
            .toList())
      // Coverage-ignore(suite): Not run.
      new Foo(s.length, bar(s)),
    for (String s
        in args
            .map(
              // Coverage-ignore(suite): Not run.
              (s) => " - $s",
            )
            .toList())
      // Coverage-ignore(suite): Not run.
      new Foo(s.length, bar(s)),
    if (1 + 1 == 3)
      // Coverage-ignore(suite): Not run.
      new Foo(42, "42"),
  ]);
}

// Coverage-ignore(suite): Not run.
String bar(String s) {
  return s.trim();
}

// Coverage-ignore(suite): Not run.
class Foo {
  final int length;
  final String s;

  Foo(this.length, this.s);
}
