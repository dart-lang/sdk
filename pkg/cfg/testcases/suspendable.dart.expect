--- asyncStar1
B0 = EntryBlock() dominates:(B8, B7)
  v2 = Constant(<int>)
  v4 = Constant("before")
  v11 = Constant(null)
  v13 = Constant("after")
  v1 = Parameter(a)
  EnterSuspendableFunction(v2)
  DirectCall print(v4)
  v9 = Suspend asyncYield(v1)
  Branch(v9, true: B7, false: B8)
B7 = TargetBlock() idom:B0
  Return(v11)
B8 = TargetBlock() idom:B0
  DirectCall print(v13)
  Return(v11)

